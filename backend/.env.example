# ── Variables para Docker Compose ──────────────────────────────────────────────
# Copiar este fichero a .env en la raíz del repo:
#   cp backend/.env.example .env
#
# Docker Compose sustituye ${POSTGRES_USER} etc. en docker-compose.yml
# e inyecta DATABASE_URL como variable de entorno al contenedor del backend.

POSTGRES_USER=fuzhify
POSTGRES_PASSWORD=fuzhify
POSTGRES_DB=fuzhify

# ── Variables del backend (leídas por pydantic-settings) ───────────────────────
# DATABASE_URL se construye automáticamente en docker-compose desde las variables
# anteriores. Solo hace falta definirla manualmente para desarrollo local sin Docker.
#GEMINI_API_KEY será enviado por el desarrollador o se puede obtener gratis en https://console.cloud.google.com/apis/credentials

DATABASE_URL=postgresql+asyncpg://fuzhify:fuzhify@postgres:5432/fuzhify
# Si usas Anthropic, Gemini o OpenAI, define la clave API correspondiente. 
GEMINI_API_KEY=

ANTHROPIC_API_KEY=

OPENAI_API_KEY=

# ── Opcionales (tienen valores por defecto en config.py) ───────────────────────
# DATA_DIR=data/jobs         Directorio donde se guardan los archivos de cada job
# MAX_UPLOAD_MB=100          Tamaño máximo del CSV subido (en MB)
